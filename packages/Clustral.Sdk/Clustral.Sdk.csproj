<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AllowUnsafeBlocks>false</AllowUnsafeBlocks>
    <RootNamespace>Clustral.Sdk</RootNamespace>
    <AssemblyName>Clustral.Sdk</AssemblyName>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Google.Protobuf"         Version="3.29.3" />
    <PackageReference Include="Grpc.Net.Client"         Version="2.67.0" />
    <PackageReference Include="Grpc.Tools"              Version="2.67.0" PrivateAssets="All" />
    <PackageReference Include="YamlDotNet"              Version="16.3.0" />
  </ItemGroup>

  <!--
    Proto stubs are generated by Grpc.Tools at build time into obj/.
    Do not edit generated files.  GrpcServices="Both" emits client + server
    stubs so that ControlPlane (server) and Agent/CLI (client) can both depend
    on this project without needing separate Sdk variants.
  -->
  <ItemGroup>
    <Protobuf Include="../../packages/proto/cluster.proto"
              GrpcServices="Both"
              ProtoRoot="../../packages/proto" />
    <Protobuf Include="../../packages/proto/tunnel.proto"
              GrpcServices="Both"
              ProtoRoot="../../packages/proto" />
    <Protobuf Include="../../packages/proto/auth.proto"
              GrpcServices="Both"
              ProtoRoot="../../packages/proto" />
  </ItemGroup>

</Project>
