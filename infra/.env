# Clustral Infrastructure — Environment Variables
#
# These defaults work out of the box after `git clone`.

# ── Keycloak ─────────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# ── RabbitMQ ─────────────────────────────────────────────────────
RABBITMQ_DEFAULT_USER=clustral
RABBITMQ_DEFAULT_PASS=clustral
