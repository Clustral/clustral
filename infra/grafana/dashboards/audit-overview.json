{
  "dashboard": {
    "title": "Audit Overview",
    "uid": "clustral-audit-overview",
    "tags": ["clustral", "audit"],
    "timezone": "browser",
    "panels": [
      {
        "title": "Audit Events / Minute",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "targets": [
          {
            "expr": "rate(masstransit_receive_total[1m]) * 60",
            "legendFormat": "{{service_name}}"
          }
        ]
      },
      {
        "title": "Events by Category",
        "type": "piechart",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "targets": [
          {
            "expr": "sum by (message_type) (masstransit_receive_total)",
            "legendFormat": "{{message_type}}"
          }
        ]
      },
      {
        "title": "Consumer Duration (p95)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(masstransit_receive_duration_seconds_bucket[5m]))",
            "legendFormat": "p95"
          }
        ]
      },
      {
        "title": "Recent Traces",
        "type": "table",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
        "datasource": { "type": "tempo", "uid": "tempo" },
        "targets": [
          {
            "queryType": "search",
            "serviceName": "clustral-audit-service",
            "limit": 20
          }
        ]
      }
    ],
    "time": { "from": "now-1h", "to": "now" },
    "refresh": "30s"
  }
}
