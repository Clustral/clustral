{
  "title": "Audit Overview",
  "uid": "clustral-audit-overview",
  "tags": ["clustral", "audit"],
  "timezone": "browser",
  "schemaVersion": 39,
  "panels": [
    {
      "title": "Audit Events / Minute",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(masstransit_receive_total{job=\"audit-service\"}[1m]) * 60",
          "legendFormat": "{{message_type}}"
        }
      ]
    },
    {
      "title": "Events by Message Type",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (message_type) (masstransit_receive_total{job=\"audit-service\"})",
          "legendFormat": "{{message_type}}"
        }
      ]
    },
    {
      "title": "Consumer Duration (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(masstransit_receive_duration_seconds_bucket{job=\"audit-service\"}[5m]))",
          "legendFormat": "p95 {{message_type}}"
        }
      ]
    },
    {
      "title": "Recent Traces",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        {
          "queryType": "nativeSearch",
          "serviceName": "clustral-audit-service",
          "limit": 20
        }
      ]
    }
  ],
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s"
}
