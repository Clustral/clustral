# Clustral Application Stack — Environment Variables
#
# These defaults work out of the box after `git clone`.
# Edit HOST_IP to match your machine's IP address.

# ── Host IP / Domain ─────────────────────────────────────────────
# Replace with your machine's IP or domain name.
HOST_IP=192.168.88.4

# ── MongoDB ──────────────────────────────────────────────────────
MONGO_CONNECTION_STRING=mongodb://mongo:27017
MONGO_DATABASE_NAME=clustral
MONGO_AUDIT_DATABASE_NAME=clustral-audit

# ── OIDC / Keycloak ─────────────────────────────────────────────
OIDC_AUTHORITY=http://${HOST_IP}:8080/realms/clustral
OIDC_METADATA_ADDRESS=http://${HOST_IP}:8080/realms/clustral/.well-known/openid-configuration
OIDC_CLIENT_ID=clustral-control-plane
OIDC_AUDIENCE=clustral-control-plane
OIDC_REQUIRE_HTTPS=false
OIDC_WEB_ISSUER=http://${HOST_IP}:8080/realms/clustral
OIDC_WEB_CLIENT_ID=clustral-web
OIDC_WEB_CLIENT_SECRET=clustral-web-secret

# ── RabbitMQ ─────────────────────────────────────────────────────
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=clustral
RABBITMQ_PASS=clustral

# ── Web UI ───────────────────────────────────────────────────────
NEXTAUTH_URL=https://${HOST_IP}
CONTROLPLANE_URL=http://controlplane:5100
CONTROLPLANE_PUBLIC_URL=https://${HOST_IP}
AUTH_SECRET=lXBA6UgneVKkAZSlKqDqLTuXigHVoScA
AUDIT_SERVICE_URL=http://audit-service:5200

# ── Certificate Authority ────────────────────────────────────────
CA_CERT_PATH=/etc/clustral/ca/ca.crt
CA_KEY_PATH=/etc/clustral/ca/ca.key
