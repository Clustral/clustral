# Clustral Application Stack — Environment Variables
#
# These defaults work out of the box after `git clone`.
# Edit HOST_IP to match your machine's IP address.

# ── Host IP / Domain ─────────────────────────────────────────────
# Replace with your machine's IP or domain name.
HOST_IP=192.168.88.4

# ── MongoDB ──────────────────────────────────────────────────────
MONGO_CONNECTION_STRING=mongodb://mongo:27017
MONGO_DATABASE_NAME=clustral
MONGO_AUDIT_DATABASE_NAME=clustral-audit

# ── OIDC / Keycloak ─────────────────────────────────────────────
OIDC_AUTHORITY=http://${HOST_IP}:8080/realms/clustral
OIDC_METADATA_ADDRESS=http://${HOST_IP}:8080/realms/clustral/.well-known/openid-configuration
OIDC_CLIENT_ID=clustral-control-plane
OIDC_AUDIENCE=clustral-control-plane
OIDC_REQUIRE_HTTPS=false
# JWT claim used as the authenticated user name. "preferred_username" works for
# Keycloak; Auth0/Okta/Azure AD may use "email", "name", or "upn".
OIDC_NAME_CLAIM_TYPE=preferred_username
OIDC_WEB_ISSUER=http://${HOST_IP}:8080/realms/clustral
OIDC_WEB_CLIENT_ID=clustral-web
OIDC_WEB_CLIENT_SECRET=clustral-web-secret

# ── RabbitMQ ─────────────────────────────────────────────────────
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=clustral
RABBITMQ_PASS=clustral

# ── Web UI ───────────────────────────────────────────────────────
NEXTAUTH_URL=https://${HOST_IP}
CONTROLPLANE_URL=http://api-gateway:8080
CONTROLPLANE_PUBLIC_URL=https://${HOST_IP}
AUTH_SECRET=lXBA6UgneVKkAZSlKqDqLTuXigHVoScA
AUDIT_SERVICE_URL=http://api-gateway:8080/audit-api
AUDIT_SERVICE_PUBLIC_URL=https://${HOST_IP}/audit-api

# ── Certificate Authority ────────────────────────────────────────
CA_CERT_PATH=/etc/clustral/ca/ca.crt
CA_KEY_PATH=/etc/clustral/ca/ca.key

# ── Kubeconfig Credential TTLs (ControlPlane) ────────────────────
# Default lifetime granted when caller doesn't request a specific TTL.
CREDENTIAL_DEFAULT_TTL=08:00:00
# Maximum lifetime a caller can request (cap).
CREDENTIAL_MAX_TTL=08:00:00

# ── kubectl Proxy (ControlPlane) ─────────────────────────────────
# Max wait for agent response over gRPC tunnel (k8s API timeouts pass through).
PROXY_TUNNEL_TIMEOUT=00:02:00
# Per-credential token bucket rate limiting (defaults match k8s client-go).
PROXY_RATE_LIMITING_ENABLED=true
PROXY_RATE_LIMITING_BURST_SIZE=200
PROXY_RATE_LIMITING_REQUESTS_PER_SECOND=100
PROXY_RATE_LIMITING_QUEUE_SIZE=50
