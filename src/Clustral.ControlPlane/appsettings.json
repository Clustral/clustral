{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.Authentication": "Error"
    }
  },
  "AllowedHosts": "*",

  "ConnectionStrings": {
    "Clustral": "mongodb://localhost:27017"
  },

  "MongoDB": {
    "DatabaseName": "clustral"
  },

  "Keycloak": {
    "Authority": "http://localhost:8080/realms/clustral",
    "ClientId": "clustral-control-plane",
    "Audience": "clustral-control-plane",
    "RequireHttpsMetadata": false,
    "DefaultKubeconfigCredentialTtl": "08:00:00",
    "MaxKubeconfigCredentialTtl": "08:00:00"
  },

  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5000"
      },
      "Grpc": {
        "Url": "http://0.0.0.0:5001",
        "Protocols": "Http2"
      }
    }
  }
}
