{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.Authentication": "Error"
    }
  },
  "AllowedHosts": "*",
  "MongoDB": {},
  "RabbitMQ": {
    "Host": "localhost",
    "Port": 5672,
    "VHost": "/",
    "User": "clustral",
    "Pass": "clustral"
  },
  "Proxy": {
    "TunnelTimeout": "00:02:00",
    "RateLimiting": {
      "Enabled": true,
      "BurstSize": 200,
      "RequestsPerSecond": 100,
      "QueueSize": 50
    }
  },
  "CertificateAuthority": {
    "CaCertPath": "",
    "CaKeyPath": "",
    "ClientCertValidityDays": 395,
    "JwtValidityDays": 30
  },
  "Oidc": {
    "RequireHttpsMetadata": true,
    "DefaultKubeconfigCredentialTtl": "08:00:00",
    "MaxKubeconfigCredentialTtl": "08:00:00"
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5100"
      }
    }
  }
}
