{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },

  "Agent": {
    "ControlPlaneUrl":        "http://localhost:5001",
    "CredentialPath":         "~/.clustral/agent-dev.token",
    "KubernetesApiUrl":       "https://127.0.0.1:6443",
    "KubernetesSkipTlsVerify": true,
    "Reconnect": {
      "InitialDelay": "00:00:01",
      "MaxDelay":     "00:00:10"
    }
  }
}
