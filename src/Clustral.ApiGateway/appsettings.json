{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Yarp": "Information"
      }
    }
  },
  "Oidc": {
    "Authority": "http://localhost:8080/realms/clustral",
    "Audience": "clustral-control-plane",
    "RequireHttpsMetadata": false
  },
  "InternalJwt": {
    "PrivateKeyPath": ""
  },
  "Cors": {
    "AllowedOrigins": ["https://localhost", "http://localhost:5173"]
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:8080"
      },
      "Grpc": {
        "Url": "http://0.0.0.0:5443",
        "Protocols": "Http2"
      }
    }
  },
  "ReverseProxy": {
    "Routes": {
      "api-route": {
        "ClusterId": "controlplane",
        "AuthorizationPolicy": "default",
        "RateLimiterPolicy": "api",
        "Match": {
          "Path": "/api/{**catch-all}"
        }
      },
      "healthz-route": {
        "ClusterId": "controlplane",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "/healthz/{**catch-all}"
        }
      },
      "audit-route": {
        "ClusterId": "audit-service",
        "AuthorizationPolicy": "default",
        "RateLimiterPolicy": "api",
        "Match": {
          "Path": "/audit-api/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/audit-api" }
        ]
      },
      "grpc-route": {
        "ClusterId": "controlplane-grpc",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "/{**catch-all}",
          "Hosts": ["*"]
        },
        "Metadata": {
          "ListenPort": "5443"
        }
      }
    },
    "Clusters": {
      "controlplane": {
        "Destinations": {
          "default": {
            "Address": "http://controlplane:5100"
          }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:10",
            "Timeout": "00:00:10",
            "Path": "/healthz"
          }
        }
      },
      "audit-service": {
        "Destinations": {
          "default": {
            "Address": "http://audit-service:5200"
          }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:10",
            "Timeout": "00:00:10",
            "Path": "/swagger"
          }
        }
      },
      "controlplane-grpc": {
        "Destinations": {
          "default": {
            "Address": "https://controlplane:5443"
          }
        },
        "HttpRequest": {
          "Version": "2",
          "VersionPolicy": "RequestVersionExact"
        }
      }
    }
  }
}
